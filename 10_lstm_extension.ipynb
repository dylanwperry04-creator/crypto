   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 10 — LSTM Time-Series Extension (Experimental)\n",
    "**Purpose:** Extend the baseline classifiers with an LSTM for sequential pattern learning.\n",
    "\n",
    "This is an add-on notebook. The main app uses the sklearn/XGBoost models.\n",
    "Run this to train an LSTM alternative and compare performance.\n",
    "\n",
    "Note: For a full Temporal Fusion Transformer (TFT), install pytorch-forecasting and see the comment block at the bottom."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import json\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "try:\n",
    "    import tensorflow as tf\n",
    "    from tensorflow import keras\n",
    "    from tensorflow.keras import layers\n",
    "    TF_OK = True\n",
    "    print(\"TensorFlow version:\", tf.__version__)\n",
    "except ImportError:\n",
    "    TF_OK = False\n",
    "    print(\"⚠️  TensorFlow not found. Install with: pip install tensorflow\")\n",
    "    print(\"    Proceeding to show architecture only.\")\n",
    "\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics import f1_score, roc_auc_score\n",
    "\n",
    "COIN     = \"Bitcoin\"\n",
    "SEQ_LEN  = 30    # Look-back window in days\n",
    "DATE_MIN = pd.Timestamp(\"2022-01-01\")\n",
    "DATE_MAX = pd.Timestamp(\"2023-06-22\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load features ────────────────────────────────────────────────────────────\n",
    "df = pd.read_csv(\"features_bitcoin.csv\", parse_dates=[\"date\"]).sort_values(\"date\")\n",
    "df = df[(df[\"date\"] >= DATE_MIN) & (df[\"date\"] <= DATE_MAX)].copy()\n",
    "\n",
    "# Optionally merge Twitter features\n",
    "try:\n",
    "    tw = pd.read_csv(\"bitcoin_twitter_daily_new.csv\", parse_dates=[\"date\"])\n",
    "    tw_cols = [c for c in tw.columns if c not in [\"date\", \"coin\"]]\n",
    "    df = df.merge(tw[[\"date\"] + tw_cols], on=\"date\", how=\"left\")\n",
    "    df[tw_cols] = df[tw_cols].fillna(df[tw_cols].median())\n",
    "    print(\"Merged Twitter features.\")\n",
    "except FileNotFoundError:\n",
    "    print(\"bitcoin_twitter_daily_new.csv not found — using price features only.\")\n",
    "\n",
    "exclude = [\"coin\", \"date\", \"open\", \"high\", \"low\", \"close\", \"volume\", \"pct_change_raw\", \"target\"]\n",
    "feat_cols = [c for c in df.columns if c not in exclude]\n",
    "df = df.dropna(subset=[\"target\"]).copy()\n",
    "df[feat_cols] = df[feat_cols].fillna(0)\n",
    "\n",
    "print(f\"Rows: {len(df)}  |  Features: {len(feat_cols)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build sequences ──────────────────────────────────────────────────────────\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(df[feat_cols].values)\n",
    "y_all    = df[\"target\"].astype(int).values\n",
    "\n",
    "def make_sequences(X, y, seq_len):\n",
    "    Xs, ys = [], []\n",
    "    for i in range(seq_len, len(X)):\n",
    "        Xs.append(X[i-seq_len:i])\n",
    "        ys.append(y[i])\n",
    "    return np.array(Xs), np.array(ys)\n",
    "\n",
    "X_seq, y_seq = make_sequences(X_scaled, y_all, SEQ_LEN)\n",
    "n = len(X_seq)\n",
    "t1, t2 = int(n * 0.70), int(n * 0.85)\n",
    "X_train, y_train = X_seq[:t1], y_seq[:t1]\n",
    "X_val,   y_val   = X_seq[t1:t2], y_seq[t1:t2]\n",
    "X_test,  y_test  = X_seq[t2:], y_seq[t2:]\n",
    "\n",
    "print(f\"Sequences — Train:{len(X_train)}  Val:{len(X_val)}  Test:{len(X_test)}\")\n",
    "print(f\"Input shape per sample: {X_train.shape[1:]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── LSTM architecture ────────────────────────────────────────────────────────\n",
    "if TF_OK:\n",
    "    inp = keras.Input(shape=(SEQ_LEN, len(feat_cols)))\n",
    "    x   = layers.LSTM(64, return_sequences=True, dropout=0.2)(inp)\n",
    "    x   = layers.LSTM(32, dropout=0.2)(x)\n",
    "    x   = layers.Dense(16, activation=\"relu\")(x)\n",
    "    out = layers.Dense(1,  activation=\"sigmoid\")(x)\n",
    "\n",
    "    model = keras.Model(inp, out)\n",
    "    model.compile(\n",
    "        optimizer=keras.optimizers.Adam(1e-3),\n",
    "        loss=\"binary_crossentropy\",\n",
    "        metrics=[\"accuracy\"]\n",
    "    )\n",
    "    model.summary()\n",
    "else:\n",
    "    print(\"\"\"\n",
    "LSTM Architecture (TF not installed):\n",
    "  Input:  (batch, 30, n_features)\n",
    "  LSTM-1: 64 units, return_sequences=True, dropout=0.2\n",
    "  LSTM-2: 32 units, dropout=0.2\n",
    "  Dense:  16 units, relu\n",
    "  Output: 1 unit, sigmoid\n",
    "\"\"\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train ────────────────────────────────────────────────────────────────────\n",
    "if TF_OK:\n",
    "    cb = [\n",
    "        keras.callbacks.EarlyStopping(patience=10, restore_best_weights=True),\n",
    "        keras.callbacks.ReduceLROnPlateau(patience=5, factor=0.5, verbose=0),\n",
    "    ]\n",
    "    class_weight = {0: 1.0, 1: float(np.sum(y_train==0)/np.sum(y_train==1))}\n",
    "\n",
    "    history = model.fit(\n",
    "        X_train, y_train,\n",
    "        validation_data=(X_val, y_val),\n",
    "        epochs=60,\n",
    "        batch_size=32,\n",
    "        class_weight=class_weight,\n",
    "        callbacks=cb,\n",
    "        verbose=1\n",
    "    )\n",
    "\n",
    "    # Evaluate\n",
    "    prob_test = model.predict(X_test).flatten()\n",
    "    best_thr  = max(np.linspace(0.3, 0.7, 41), key=lambda t: f1_score(y_test, (prob_test>=t).astype(int), zero_division=0))\n",
    "    y_pred    = (prob_test >= best_thr).astype(int)\n",
    "\n",
    "    print(f\"\\nLSTM Test Results:\")\n",
    "    print(f\"  F1:      {f1_score(y_test, y_pred):.4f}\")\n",
    "    print(f\"  ROC-AUC: {roc_auc_score(y_test, prob_test):.4f}\")\n",
    "    print(f\"  Thresh:  {best_thr:.2f}\")\n",
    "\n",
    "    # Save\n",
    "    model.save(\"lstm_bitcoin_combined.keras\")\n",
    "    print(\"\\n✅ Saved lstm_bitcoin_combined.keras\")\n",
    "else:\n",
    "    print(\"Install TensorFlow to train. pip install tensorflow\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## TFT Extension\n",
    "For a Temporal Fusion Transformer, install [pytorch-forecasting](https://pytorch-forecasting.readthedocs.io/):\n",
    "```\n",
    "pip install pytorch-forecasting pytorch-lightning\n",
    "```\n",
    "Then use `TemporalFusionTransformer` with a `TimeSeriesDataSet`. \n",
    "The TFT handles variable importance natively and is well-suited for multi-step probabilistic forecasting."
   ]
  }
 ],

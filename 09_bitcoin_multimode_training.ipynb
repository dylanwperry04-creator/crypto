   "source": [
    "# Notebook 09 — Bitcoin Multi-Mode Training\n",
    "Trains three separate Bitcoin model modes:\n",
    "1. **price_only** — technical + calendar features\n",
    "2. **twitter_only** — Twitter sentiment features only\n",
    "3. **combined** — price + Twitter features\n",
    "\n",
    "Date range locked to 2022-01-01 → 2023-06-22 (Twitter overlap window).\n",
    "\n",
    "ETH/DOGE remain price-only from the main pipeline.\n",
    "\n",
    "**Run after:** 08_twitter_NEW_DATASET.ipynb and 03_feature_engineering_FINAL_updated.ipynb"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import joblib\n",
    "import json\n",
    "import shutil\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import f1_score, precision_recall_curve, auc, roc_auc_score\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "import lightgbm as lgb\n",
    "import xgboost as xgb\n",
    "\n",
    "# ── Config ─────────────────────────────────────────────────────────────────\n",
    "DATE_MIN = pd.Timestamp(\"2022-01-01\")\n",
    "DATE_MAX = pd.Timestamp(\"2023-06-22\")\n",
    "MODES    = [\"price_only\", \"twitter_only\", \"combined\"]\n",
    "\n",
    "print(f\"Bitcoin training window: {DATE_MIN.date()} → {DATE_MAX.date()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load data ───────────────────────────────────────────────────────────────\n",
    "# Price features (full Bitcoin feature file from NB03)\n",
    "btc_features = pd.read_csv(\"features_bitcoin.csv\", parse_dates=[\"date\"])\n",
    "\n",
    "# New Twitter daily features from NB08\n",
    "tw = pd.read_csv(\"bitcoin_twitter_daily_new.csv\", parse_dates=[\"date\"])\n",
    "\n",
    "# Filter both to the overlapping window\n",
    "btc_features = btc_features[(btc_features[\"date\"] >= DATE_MIN) & (btc_features[\"date\"] <= DATE_MAX)].copy()\n",
    "tw           = tw[(tw[\"date\"] >= DATE_MIN) & (tw[\"date\"] <= DATE_MAX)].copy()\n",
    "\n",
    "print(f\"btc_features window rows: {len(btc_features)}\")\n",
    "print(f\"twitter daily rows:       {len(tw)}\")\n",
    "\n",
    "# Load price-feature column list\n",
    "price_feat_cols = pd.read_csv(\"feature_cols_bitcoin.csv\")[\"feature\"].tolist()\n",
    "# Remove old twitter columns if any\n",
    "price_feat_cols = [c for c in price_feat_cols if \"twitter\" not in c.lower() and \"sentiment\" not in c.lower() and \"tweet\" not in c.lower()]\n",
    "print(f\"Price feature columns: {len(price_feat_cols)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build per-mode feature sets ─────────────────────────────────────────────\n",
    "twitter_feat_cols = [\n",
    "    \"weighted_sentiment_mean\", \"weighted_sentiment_std\",\n",
    "    \"weighted_positive_share\", \"weighted_negative_share\",\n",
    "    \"weighted_tweet_count\",    \"total_engagement\",\n",
    "    \"average_engagement\",      \"max_engagement\",\n",
    "    \"sent_ma3\", \"sent_ma7\", \"sent_chg3\", \"sent_chg7\",\n",
    "    \"eng_ma3\",  \"eng_ma7\",\n",
    "]\n",
    "twitter_feat_cols = [c for c in twitter_feat_cols if c in tw.columns]\n",
    "print(f\"Twitter feature columns available: {len(twitter_feat_cols)}\")\n",
    "\n",
    "# Merge price + twitter\n",
    "btc_merged = btc_features.merge(tw[[\"date\"] + twitter_feat_cols], on=\"date\", how=\"left\")\n",
    "\n",
    "# Fill missing Twitter days with column medians (sparse days get neutral fill)\n",
    "tw_medians = btc_merged[twitter_feat_cols].median()\n",
    "btc_merged[twitter_feat_cols] = btc_merged[twitter_feat_cols].fillna(tw_medians)\n",
    "\n",
    "btc_merged = btc_merged.dropna(subset=[\"target\"]).copy()\n",
    "print(f\"Merged rows after dropna target: {len(btc_merged)}\")\n",
    "print(f\"Target balance: {btc_merged['target'].mean():.1%} UP days\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Time-aware split ────────────────────────────────────────────────────────\n",
    "def time_split(df, val_frac=0.15, test_frac=0.15):\n",
    "    n = len(df)\n",
    "    t1 = int(n * (1 - val_frac - test_frac))\n",
    "    t2 = int(n * (1 - test_frac))\n",
    "    return df.iloc[:t1].copy(), df.iloc[t1:t2].copy(), df.iloc[t2:].copy()\n",
    "\n",
    "train, val, test = time_split(btc_merged)\n",
    "print(f\"Train: {len(train)} | Val: {len(val)} | Test: {len(test)}\")\n",
    "print(f\"Train dates: {train['date'].min().date()} → {train['date'].max().date()}\")\n",
    "print(f\"Test  dates: {test['date'].min().date()}  → {test['date'].max().date()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Training helpers ────────────────────────────────────────────────────────\n",
    "def make_candidates():\n",
    "    return {\n",
    "        \"lr\": Pipeline([(\"scaler\", StandardScaler()), (\"clf\", LogisticRegression(C=0.5, max_iter=1000, class_weight=\"balanced\"))]),\n",
    "        \"rf\": RandomForestClassifier(n_estimators=300, max_depth=6, class_weight=\"balanced\", random_state=42, n_jobs=-1),\n",
    "        \"xgb\": xgb.XGBClassifier(n_estimators=300, max_depth=4, learning_rate=0.05, use_label_encoder=False, eval_metric=\"logloss\", random_state=42),\n",
    "        \"lgb\": lgb.LGBMClassifier(n_estimators=300, num_leaves=31, learning_rate=0.05, class_weight=\"balanced\", random_state=42, verbose=-1),\n",
    "    }\n",
    "\n",
    "def best_threshold(y_true, probs):\n",
    "    return max(\n",
    "        np.linspace(0.30, 0.70, 41),\n",
    "        key=lambda t: f1_score(y_true, (probs >= t).astype(int), zero_division=0)\n",
    "    )\n",
    "\n",
    "def evaluate(model, X_val, y_val, X_test, y_test, feat_cols):\n",
    "    val_prob  = model.predict_proba(X_val)[:, 1]\n",
    "    thr       = best_threshold(y_val, val_prob)\n",
    "    test_prob = model.predict_proba(X_test)[:, 1]\n",
    "    y_pred    = (test_prob >= thr).astype(int)\n",
    "    prec, rec, _ = precision_recall_curve(y_test, test_prob)\n",
    "    return {\n",
    "        \"threshold\": float(thr),\n",
    "        \"f1_class1\": float(f1_score(y_test, y_pred, zero_division=0)),\n",
    "        \"roc_auc\":   float(roc_auc_score(y_test, test_prob)),\n",
    "        \"pr_auc\":    float(auc(rec, prec)),\n",
    "    }\n",
    "\n",
    "print(\"Training helpers ready.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train all 3 modes ───────────────────────────────────────────────────────\n",
    "MODE_FEAT = {\n",
    "    \"price_only\":   price_feat_cols,\n",
    "    \"twitter_only\": twitter_feat_cols,\n",
    "    \"combined\":     price_feat_cols + twitter_feat_cols,\n",
    "}\n",
    "\n",
    "all_results = []\n",
    "best_by_mode = {}\n",
    "\n",
    "for mode in MODES:\n",
    "    fc = MODE_FEAT[mode]\n",
    "    fc = [c for c in fc if c in btc_merged.columns]\n",
    "\n",
    "    X_train = train[fc].fillna(0).values\n",
    "    y_train = train[\"target\"].astype(int).values\n",
    "    X_val   = val[fc].fillna(0).values\n",
    "    y_val   = val[\"target\"].astype(int).values\n",
    "    X_test  = test[fc].fillna(0).values\n",
    "    y_test  = test[\"target\"].astype(int).values\n",
    "\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"MODE: {mode.upper()}  |  features: {len(fc)}\")\n",
    "\n",
    "    candidates = make_candidates()\n",
    "    mode_results = []\n",
    "\n",
    "    for name, model in candidates.items():\n",
    "        model.fit(X_train, y_train)\n",
    "        metrics = evaluate(model, X_val, y_val, X_test, y_test, fc)\n",
    "        metrics.update({\"mode\": mode, \"model_type\": name})\n",
    "        mode_results.append(metrics)\n",
    "        all_results.append(metrics)\n",
    "        print(f\"  {name:4s}  F1={metrics['f1_class1']:.4f}  ROC={metrics['roc_auc']:.4f}  PR-AUC={metrics['pr_auc']:.4f}  thr={metrics['threshold']:.2f}\")\n",
    "\n",
    "    # Pick best by PR-AUC (favours precision-recall balance for imbalanced)\n",
    "    best_row = sorted(mode_results, key=lambda x: (x[\"pr_auc\"], x[\"f1_class1\"]), reverse=True)[0]\n",
    "    best_name = best_row[\"model_type\"]\n",
    "    print(f\"  → BEST: {best_name}\")\n",
    "\n",
    "    # Retrain best on train+val\n",
    "    X_tv = np.vstack([X_train, X_val])\n",
    "    y_tv = np.concatenate([y_train, y_val])\n",
    "    best_model = make_candidates()[best_name]\n",
    "    best_model.fit(X_tv, y_tv)\n",
    "\n",
    "    save_path = f\"bitcoin_{mode}_model.joblib\"\n",
    "    joblib.dump(best_model, save_path)\n",
    "    print(f\"  ✅ Saved {save_path}\")\n",
    "\n",
    "    feat_path = f\"bitcoin_{mode}_feature_cols.csv\"\n",
    "    pd.DataFrame({\"feature\": fc}).to_csv(feat_path, index=False)\n",
    "    print(f\"  ✅ Saved {feat_path}\")\n",
    "\n",
    "    best_by_mode[mode] = {\n",
    "        **best_row,\n",
    "        \"pipeline\":      best_name,\n",
    "        \"n_features\":    len(fc),\n",
    "        \"feature_file\":  feat_path,\n",
    "        \"model_file\":    save_path,\n",
    "        \"twitter_range\": {\"date_min\": str(DATE_MIN.date()), \"date_max\": str(DATE_MAX.date())},\n",
    "        \"coin\":          \"Bitcoin\",\n",
    "    }\n",
    "\n",
    "print(\"\\n✅ All modes trained.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Save metadata ───────────────────────────────────────────────────────────\n",
    "# Load existing best_model_metadata.json (ETH/DOGE already there)\n",
    "meta_path = Path(\"best_model_metadata.json\")\n",
    "if meta_path.exists():\n",
    "    with open(meta_path) as f:\n",
    "        metadata = json.load(f)\n",
    "else:\n",
    "    metadata = {}\n",
    "\n",
    "# Add/update Bitcoin multi-mode metadata\n",
    "metadata[\"Bitcoin_modes\"] = best_by_mode\n",
    "\n",
    "# For backward compat: Bitcoin default mode = combined (or best available)\n",
    "best_combined = best_by_mode.get(\"combined\", best_by_mode.get(\"price_only\", {}))\n",
    "metadata[\"Bitcoin\"] = {\n",
    "    \"pipeline\":      best_combined.get(\"pipeline\"),\n",
    "    \"coin\":          \"Bitcoin\",\n",
    "    \"threshold\":     best_combined.get(\"threshold\", 0.5),\n",
    "    \"f1_class1\":     best_combined.get(\"f1_class1\", 0),\n",
    "    \"roc_auc\":       best_combined.get(\"roc_auc\", 0),\n",
    "    \"pr_auc\":        best_combined.get(\"pr_auc\", 0),\n",
    "    \"default_mode\":  \"combined\",\n",
    "    \"twitter_range\": {\"date_min\": str(DATE_MIN.date()), \"date_max\": str(DATE_MAX.date())},\n",
    "}\n",
    "\n",
    "with open(meta_path, \"w\") as f:\n",
    "    json.dump(metadata, f, indent=2)\n",
    "\n",
    "print(\"✅ Updated best_model_metadata.json\")\n",
    "print(json.dumps(best_by_mode, indent=2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Save deploy demo rows for all 3 modes ───────────────────────────────────\n",
    "# The app needs pre-computed rows with all features so it can score them\n",
    "all_demo = []\n",
    "for mode in MODES:\n",
    "    fc = MODE_FEAT[mode]\n",
    "    fc = [c for c in fc if c in btc_merged.columns]\n",
    "    # Use test set rows as demo\n",
    "    rows = test[[\"date\", \"target\"] + fc].copy()\n",
    "    rows[\"coin\"]   = \"Bitcoin\"\n",
    "    rows[\"mode\"]   = mode\n",
    "    rows[\"actual_target\"] = rows[\"target\"]\n",
    "    all_demo.append(rows)\n",
    "\n",
    "demo_btc = pd.concat(all_demo, ignore_index=True)\n",
    "demo_btc[\"date\"] = pd.to_datetime(demo_btc[\"date\"]).dt.strftime(\"%Y-%m-%d\")\n",
    "demo_btc.to_csv(\"deploy_demo_rows_bitcoin_modes.csv\", index=False)\n",
    "print(f\"✅ Saved deploy_demo_rows_bitcoin_modes.csv  shape={demo_btc.shape}\")\n",
    "print(demo_btc[[\"date\", \"coin\", \"mode\", \"actual_target\"]].head(9))"
   ]
  }
